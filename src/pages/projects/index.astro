---
// src/pages/projects/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryColors: Record<string, string> = {
  AI:      '#A855F7',
  Systems: '#2DD4BF',
  Web:     '#38BDF8',
  Data:    '#FB923C',
};
const usedCats = [...new Set(projects.map((p) => p.data.category))];

const graphNodes = projects.map((p) => ({
  slug: p.id,
  title: p.data.title,
  category: p.data.category,
  tech: p.data.tech,
}));
---

<BaseLayout title="Projects | Fred Kernot">
  <h1>Projects</h1>
  <p class="intro">A similarity map of my projects: projects of similar tech stacks are positioned close together. Drag to rotate, zoom in, and click a point to open it.</p>

  <div id="graph" class="graph" aria-hidden="true">
    <button id="names-toggle" class="names-toggle" type="button">Show Names</button>
    <div class="legend">
      {usedCats.map((cat) => (
        <span class="legend-item"><i style={`background:${categoryColors[cat]}`}></i>{cat}</span>
      ))}
    </div>
  </div>

  <script id="graph-data" type="application/json" set:html={JSON.stringify({ nodes: graphNodes, colors: categoryColors })}></script>

  <div class="project-list">
    {projects.map((project) => (
      <ProjectCard
        title={project.data.title}
        description={project.data.description}
        date={project.data.date}
        tech={project.data.tech}
        url={`/projects/${project.id}`}
      />
    ))}
  </div>
</BaseLayout>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';
  import { CSS2DRenderer, CSS2DObject } from 'three/examples/jsm/renderers/CSS2DRenderer.js';

  interface RawNode { slug: string; title: string; category: string; tech: string[]; }
  interface GraphData { nodes: RawNode[]; colors: Record<string, string>; }

  const dataEl = document.getElementById('graph-data');
  const wrap = document.getElementById('graph');

  if (dataEl && wrap) {
    const data: GraphData = JSON.parse(dataEl.textContent || '{}');
    const N = data.nodes.length;

    // ---- 1. Settle a 3D force layout from tech similarity ----
    interface P { x: number; y: number; z: number; vx: number; vy: number; vz: number; }
    const pos: P[] = data.nodes.map((_, i) => {
      const a = (i / N) * Math.PI * 2;
      return { x: Math.cos(a) * 30, y: (Math.random() - 0.5) * 20, z: Math.sin(a) * 30, vx: 0, vy: 0, vz: 0 };
    });

    const jaccard = (a: string[], b: string[]) => {
      const sb = new Set(b);
      let inter = 0;
      for (const x of new Set(a)) if (sb.has(x)) inter++;
      const uni = new Set([...a, ...b]).size;
      return uni ? inter / uni : 0;
    };
    const links: { a: number; b: number; sim: number }[] = [];
    for (let i = 0; i < N; i++)
      for (let j = i + 1; j < N; j++) {
        const sim = jaccard(data.nodes[i].tech, data.nodes[j].tech);
        if (sim > 0.05) links.push({ a: i, b: j, sim });
      }

    for (let s = 0; s < 320; s++) {
      for (let i = 0; i < N; i++) {
        const a = pos[i];
        a.vx += -a.x * 0.01; a.vy += -a.y * 0.01; a.vz += -a.z * 0.01;
        for (let j = 0; j < N; j++) {
          if (i === j) continue;
          const b = pos[j];
          const dx = a.x - b.x, dy = a.y - b.y, dz = a.z - b.z;
          const d = Math.hypot(dx, dy, dz) || 0.01;
          const rep = 120 / (d * d);
          a.vx += (dx / d) * rep; a.vy += (dy / d) * rep; a.vz += (dz / d) * rep;
        }
      }
      for (const l of links) {
        const a = pos[l.a], b = pos[l.b];
        const dx = b.x - a.x, dy = b.y - a.y, dz = b.z - a.z;
        const d = Math.hypot(dx, dy, dz) || 0.01;
        const rest = 12 + (1 - l.sim) * 16;
        const f = (d - rest) * 0.02 * (0.4 + l.sim);
        a.vx += (dx / d) * f; a.vy += (dy / d) * f; a.vz += (dz / d) * f;
        b.vx -= (dx / d) * f; b.vy -= (dy / d) * f; b.vz -= (dz / d) * f;
      }
      for (const p of pos) {
        p.vx *= 0.8; p.vy *= 0.8; p.vz *= 0.8;
        p.x += p.vx; p.y += p.vy; p.z += p.vz;
      }
    }

    // ---- 2. Scene, camera, renderer ----
    let w = wrap.clientWidth, h = wrap.clientHeight;
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    wrap.appendChild(renderer.domElement);

    // A second renderer just for the HTML labels, layered over the canvas.
    const labelRenderer = new CSS2DRenderer();
    labelRenderer.setSize(w, h);
    labelRenderer.domElement.style.position = 'absolute';
    labelRenderer.domElement.style.top = '0';
    labelRenderer.domElement.style.left = '0';
    labelRenderer.domElement.style.zIndex = '1';
    labelRenderer.domElement.style.pointerEvents = 'none';
    wrap.appendChild(labelRenderer.domElement);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, w / h, 0.1, 1000);
    camera.position.set(0, 0, 80);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.08;
    controls.enablePan = false;
    controls.minDistance = 35;
    controls.maxDistance = 160;
    controls.autoRotateSpeed = 4;
    const autoAllowed = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- 3. Soft glow texture ----
    const glowTexture = (() => {
      const c = document.createElement('canvas');
      c.width = c.height = 64;
      const g = c.getContext('2d')!;
      const grd = g.createRadialGradient(32, 32, 0, 32, 32, 32);
      grd.addColorStop(0, 'rgba(255,255,255,1)');
      grd.addColorStop(0.3, 'rgba(255,255,255,0.85)');
      grd.addColorStop(1, 'rgba(255,255,255,0)');
      g.fillStyle = grd;
      g.fillRect(0, 0, 64, 64);
      return new THREE.CanvasTexture(c);
    })();

    // ---- 4. Sprites, each with an attached HTML label ----
    const BASE = 7;
    const items = data.nodes.map((n, i) => {
      const material = new THREE.SpriteMaterial({
        map: glowTexture,
        color: new THREE.Color(data.colors[n.category] || '#888888'),
        transparent: true,
        depthWrite: false,
      });
      const sprite = new THREE.Sprite(material);
      sprite.position.set(pos[i].x, pos[i].y, pos[i].z);
      sprite.scale.setScalar(BASE);
      scene.add(sprite);

      const anchor = document.createElement('div');
      anchor.className = 'label-anchor';
      const pill = document.createElement('div');
      pill.className = 'sprite-label';
      pill.textContent = n.title;
      anchor.appendChild(pill);
      sprite.add(new CSS2DObject(anchor));   // label follows the sprite automatically

      return { sprite, node: n, base: BASE, pill };
    });
    const spriteObjs: THREE.Object3D[] = items.map((it) => it.sprite);

    // ---- 5. Picking + toggle ----
    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2(2, 2);
    let hovered: (typeof items)[number] | null = null;
    let dragging = false;
    let showAll = false;
    let downX = 0, downY = 0;

    const canvasEl = renderer.domElement;
    canvasEl.addEventListener('pointermove', (e) => {
      const r = canvasEl.getBoundingClientRect();
      pointer.x = ((e.clientX - r.left) / r.width) * 2 - 1;
      pointer.y = -((e.clientY - r.top) / r.height) * 2 + 1;
    });
    canvasEl.addEventListener('pointerleave', () => { pointer.set(2, 2); });
    canvasEl.addEventListener('pointerdown', (e) => { downX = e.clientX; downY = e.clientY; });
    canvasEl.addEventListener('click', (e) => {
      if (Math.hypot(e.clientX - downX, e.clientY - downY) > 5) return;
      if (hovered) window.location.href = `/projects/${hovered.node.slug}`;
    });
    controls.addEventListener('start', () => { dragging = true; });
    controls.addEventListener('end', () => { dragging = false; });

    const namesBtn = document.getElementById('names-toggle');
    namesBtn?.addEventListener('click', () => {
      showAll = !showAll;
      namesBtn.textContent = showAll ? 'Hide names' : 'Show names';
    });

    // ---- 6. Render loop ----
    const animate = () => {
      controls.update();

      raycaster.setFromCamera(pointer, camera);
      const hits = raycaster.intersectObjects(spriteObjs, false);
      const hitSprite = hits.length ? hits[0].object : null;
      hovered = items.find((it) => it.sprite === hitSprite) ?? null;

      for (const it of items) {
        it.sprite.scale.setScalar(it === hovered ? it.base * 1.7 : it.base);
        it.pill.style.opacity = (showAll || it === hovered) ? '1' : '0';
      }
      canvasEl.style.cursor = hovered ? 'pointer' : 'default';
      controls.autoRotate = autoAllowed && !dragging && !hovered;

      renderer.render(scene, camera);
      labelRenderer.render(scene, camera);
      requestAnimationFrame(animate);
    };
    animate();

    window.addEventListener('resize', () => {
      w = wrap.clientWidth; h = wrap.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      labelRenderer.setSize(w, h);
    });
  }
</script>

<style>
  .intro { color: var(--text-muted); margin: 0 0 1rem; }

  .graph {
    position: relative;
    width: 100%;
    height: 460px;
    margin: 0.5rem 0 2rem;
  }
  .graph canvas { display: block; }

  .legend {
    position: absolute;
    left: 4px;
    bottom: 4px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 12px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .legend-item { display: flex; align-items: center; gap: 6px; }
  .legend-item i { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

  .project-list { display: flex; flex-direction: column; gap: 1rem; }

  .label-anchor { position: relative; }
  .sprite-label {
    position: absolute;
    left: 50%;
    bottom: 10px;
    transform: translateX(-50%);
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 12px;
    padding: 2px 7px;
    border-radius: 6px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.12s;
  }

  .names-toggle {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 2;
    font-family: inherit;
    font-size: 12px;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text-muted);
    cursor: pointer;
  }
  .names-toggle:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 600px) { .graph { height: 360px; } }
</style>