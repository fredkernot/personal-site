---
// src/layouts/BaseLayout.astro
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Component Props: allows pages using this layout to pass a custom title
const { title = "My Personal Website" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <div class="site-container">
    <Nav />
    
    <main>
      <slot /> 
    </main>
    
    <Footer />
  </div>
</body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    font-family: system-ui, sans-serif;
    background-color: #fafafa;
    color: #222;
  }
  
  .site-container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  main {
    flex: 1;
    padding: 2rem 0;
  }
</style>